{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arbiter.dev/schemas/v1/protocol.schema.json",
  "title": "Arbiter Protocol Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol_id",
    "roles",
    "role_cycle",
    "finalizer_slot",
    "prompts",
    "turn_instructions",
    "outcome_extraction"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "protocol_id": { "const": "debate_v1" },
    "roles": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["lead", "challenger", "counter", "auditor"] }
    },
    "role_cycle": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "string", "enum": ["challenger", "counter", "auditor"] }
    },
    "finalizer_slot": {
      "const": "A"
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lead_system",
        "challenger_system",
        "counter_system",
        "auditor_system",
        "lead_final_system"
      ],
      "properties": {
        "lead_system": { "type": "string", "minLength": 1 },
        "challenger_system": { "type": "string", "minLength": 1 },
        "counter_system": { "type": "string", "minLength": 1 },
        "auditor_system": { "type": "string", "minLength": 1 },
        "lead_final_system": { "type": "string", "minLength": 1 }
      }
    },
    "turn_instructions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lead_turn",
        "challenger_turn",
        "counter_turn",
        "auditor_turn",
        "lead_final_turn"
      ],
      "properties": {
        "lead_turn": { "type": "string", "minLength": 1 },
        "challenger_turn": { "type": "string", "minLength": 1 },
        "counter_turn": { "type": "string", "minLength": 1 },
        "auditor_turn": { "type": "string", "minLength": 1 },
        "lead_final_turn": { "type": "string", "minLength": 1 }
      }
    },
    "outcome_extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method"],
      "properties": {
        "method": { "const": "debate_v1_decision_contract" }
      }
    }
  }
}
