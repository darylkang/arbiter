{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arbiter.dev/schemas/v1/decision-contract.schema.json",
  "title": "Arbiter Decision Contract Preset",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema", "label_space", "embed_text_source"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "schema": { "type": "object", "minProperties": 1 },
    "label_space": {
      "$ref": "common.schema.json#/$defs/finite_label_space"
    },
    "embed_text_source": {
      "$ref": "common.schema.json#/$defs/embed_text_source"
    },
    "rationale_max_chars": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" }
  }
}
