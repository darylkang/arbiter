{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arbiter.dev/schemas/v1/decision-contract.schema.json",
  "title": "Arbiter Decision Contract Preset",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "finite_label_space": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "labels"],
      "properties": {
        "type": { "const": "finite" },
        "labels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  },
  "required": ["id", "schema", "label_space", "embed_text_source"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "schema": { "type": "object", "minProperties": 1 },
    "label_space": { "$ref": "#/$defs/finite_label_space" },
    "embed_text_source": {
      "type": "string",
      "enum": ["decision", "rationale", "raw_content"]
    },
    "rationale_max_chars": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" }
  }
}
