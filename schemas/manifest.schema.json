{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arbiter.dev/schemas/v1/manifest.schema.json",
  "title": "Arbiter Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "manifest_measurement_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["embedding", "grouping"],
      "properties": {
        "embedding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requested_model",
            "actual_model",
            "model_conflict",
            "embed_text_strategy",
            "normalization",
            "status",
            "generated_vectors",
            "generation_ids_count",
            "arrow_written",
            "fallback_jsonl_written"
          ],
          "properties": {
            "requested_model": { "type": "string", "minLength": 1 },
            "actual_model": { "type": ["string", "null"] },
            "model_conflict": { "type": "boolean" },
            "embed_text_strategy": {
              "type": "string",
              "enum": ["outcome_only", "outcome_or_raw_assistant"]
            },
            "normalization": { "type": "string", "minLength": 1 },
            "status": {
              "type": "string",
              "enum": ["not_generated", "arrow_generated", "jsonl_fallback"]
            },
            "generated_vectors": { "type": "integer", "minimum": 0 },
            "generation_ids_count": { "type": "integer", "minimum": 0 },
            "arrow_written": { "type": "boolean" },
            "fallback_jsonl_written": { "type": "boolean" }
          }
        },
        "grouping": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "params"],
          "properties": {
            "enabled": { "type": "boolean" },
            "params": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "algorithm",
                    "similarity_metric",
                    "tau",
                    "centroid_update_rule",
                    "ordering_rule",
                    "cluster_limit",
                    "stop_mode"
                  ],
                  "properties": {
                    "algorithm": { "type": "string", "enum": ["online_leader"] },
                    "similarity_metric": { "type": "string", "enum": ["cosine"] },
                    "tau": { "type": "number", "minimum": 0, "maximum": 1 },
                    "centroid_update_rule": {
                      "type": "string",
                      "enum": ["fixed_leader", "incremental_mean"]
                    },
                    "ordering_rule": {
                      "type": "string",
                      "enum": ["trial_id_asc"]
                    },
                    "cluster_limit": { "type": "integer", "minimum": 1 },
                    "stop_mode": {
                      "type": "string",
                      "enum": ["disabled", "advisory", "enforced"]
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "manifest_final_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["k_attempted", "k_eligible", "novelty_rate", "mean_max_sim_to_prior"],
      "properties": {
        "k_attempted": { "type": "integer", "minimum": 0 },
        "k_eligible": { "type": "integer", "minimum": 0 },
        "novelty_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "mean_max_sim_to_prior": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "group_count": { "type": ["integer", "null"], "minimum": 0 },
        "entropy": { "type": ["number", "null"], "minimum": 0 },
        "incomplete": { "type": "boolean" }
      }
    },
    "manifest_metrics_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["final"],
      "properties": {
        "final": { "$ref": "#/$defs/manifest_final_metrics" }
      }
    }
  },
  "required": [
    "schema_version",
    "arbiter_version",
    "run_id",
    "started_at",
    "stop_reason",
    "incomplete",
    "k_attempted",
    "k_eligible",
    "k_min",
    "k_min_count_rule",
    "monitoring_complete",
    "monitoring_expected_records",
    "monitoring_recorded_records"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "arbiter_version": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "stop_reason": {
      "type": "string",
      "enum": [
        "completed",
        "converged",
        "k_max_reached",
        "user_interrupt",
        "error"
      ]
    },
    "stopping_mode": {
      "type": "string"
    },
    "incomplete": {
      "type": "boolean"
    },
    "k_attempted": {
      "type": "integer",
      "minimum": 0
    },
    "k_eligible": {
      "type": "integer",
      "minimum": 0
    },
    "k_min": {
      "type": "integer",
      "minimum": 0
    },
    "k_min_count_rule": {
      "type": "string",
      "enum": [
        "k_eligible",
        "k_attempted"
      ]
    },
    "monitoring_complete": {
      "type": "boolean"
    },
    "monitoring_expected_records": {
      "type": "integer",
      "minimum": 0
    },
    "monitoring_recorded_records": {
      "type": "integer",
      "minimum": 0
    },
    "stop_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "novelty_epsilon": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "similarity_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "patience": {
          "type": "integer",
          "minimum": 1
        },
        "k_min_eligible": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strict",
        "allow_free",
        "allow_aliased",
        "contract_failure_policy"
      ],
      "properties": {
        "strict": {
          "type": "boolean"
        },
        "allow_free": {
          "type": "boolean"
        },
        "allow_aliased": {
          "type": "boolean"
        },
        "contract_failure_policy": {
          "type": "string",
          "enum": [
            "warn",
            "exclude",
            "fail"
          ]
        }
      }
    },
    "git_sha": {
      "type": "string",
      "minLength": 7
    },
    "model_catalog_version": {
      "type": "string",
      "minLength": 1
    },
    "model_catalog_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "prompt_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hash_algorithm": {
      "const": "sha256"
    },
    "config_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "plan_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "k_planned": {
      "type": "integer",
      "minimum": 0
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "arbiter_version": {
          "type": "string",
          "minLength": 1
        },
        "git_sha": {
          "type": "string",
          "minLength": 7
        },
        "config_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "plan_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "model_catalog_version": {
          "type": "string",
          "minLength": 1
        },
        "model_catalog_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "prompt_manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "hash_algorithm": {
          "const": "sha256"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "record_count": {
                "type": "integer",
                "minimum": 0
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totals"
      ],
      "properties": {
        "totals": {
          "$ref": "common.schema.json#/$defs/usage_stats"
        },
        "by_model": {
          "type": "object",
          "additionalProperties": {
            "$ref": "common.schema.json#/$defs/usage_stats"
          }
        }
      }
    },
    "measurement": { "$ref": "#/$defs/manifest_measurement_summary" },
    "metrics": { "$ref": "#/$defs/manifest_metrics_summary" }
  }
}
